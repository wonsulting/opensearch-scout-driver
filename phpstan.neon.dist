includes:
  - phpstan-baseline.neon

parameters:
  level: max
  paths:
    - src
  ignoreErrors:
    # Replaces the PHPStan 1 options checkGenericClassInNonGenericObjectType and
    # checkMissingIterableValueType (removed in PHPStan 2): this package does not
    # annotate generics / iterable value types on its Scout + Collection surface.
    - identifier: missingType.generics
    - identifier: missingType.iterableValue
